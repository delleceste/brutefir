## BruteFIR default settings — FreeBSD / OSS
## Copy to ~/.brutefir_defaults

float_bits: 64;             # internal floating-point precision (32 or 64)
sampling_rate: 192000;      # Hz — must match the OSS loopback device rate and
                            # the sample rate the FIR filter files were designed at
filter_length: 32768,16;    # partition_size, num_partitions
                            # total filter = 32768 * 16 = 524288 samples ≈ 2.7 s
                            # reduce to e.g. 4096,4 for low-latency testing
overflow_warnings: true;    # print to stderr when clipping occurs
show_progress: true;        # print block counter to stderr
max_dither_table_size: 0;   # 0 = compute dither on-the-fly (saves RAM)
allow_poll_mode: true;      # required for OSS input devices
monitor_rate: false;        # do not print sample-rate drift
powersave: false;           # never pause (OSS has no silence detection)
lock_memory: true;          # lock memory when real-time priority is set
sdf_length: -1;             # subsample filter half-length in samples (-1 = off)
safety_limit: 6;            # abort if output exceeds this many dB (0 = off)

# Path where brutefir looks for .bfio and .bflogic plugin files.
# Use an absolute path for daemon / rc.d use.
modules_path: "@BRUTEFIR_MODULES_DIR@";

# Location of the main configuration and convolver files — adjust to your setup.
#config_file: "~/digital-room-correction/brutefir.conf";
#convolver_config: "~/digital-room-correction/brutefir_convolver";

## COEFF DEFAULTS ##

coeff {
	format: "TEXT";     # file format
	attenuation: 0.0;   # attenuation in dB
	blocks: -1;         # how long in blocks (-1 = full filter length)
	skip: 0;            # how many bytes to skip at start of file
	shared_mem: false;  # allocate in shared memory
};

# input {}, output {}, and filter {} require mandatory device/channel/coeff
# fields and must be defined in brutefir.conf, not here.
